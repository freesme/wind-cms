# 本地环境变量配置（不要提交到版本控制）
# API 接口地址
NEXT_PUBLIC_API_BASE_URL=https://api.cms.gowind.cloud

# 是否启用 Mock 数据
NEXT_PUBLIC_ENABLE_MOCK=false

# 应用标题
NEXT_PUBLIC_APP_TITLE='GoWind Content Hub'

# 应用描述
NEXT_PUBLIC_APP_DESCRIPTION='A modern Content Hub built with Next.js'

# 默认语言
NEXT_PUBLIC_DEFAULT_LOCALE=zh-CN

# Token 配置
NEXT_PUBLIC_TOKEN_KEY=access_token
NEXT_PUBLIC_REFRESH_TOKEN_KEY=refresh_token
